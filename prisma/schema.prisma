generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A client workspace — each client has their own competitors, ads, etc.
model Client {
  id          String   @id @default(cuid())
  name        String
  niche       String?  @db.Text  // Client's niche/industry
  description String?  @db.Text  // Business description
  avatarDesc  String?  @db.Text  // Client's ideal customer avatar
  websiteUrl  String?
  driveFolder String?            // Google Drive folder URL
  countries   String[] @default(["ES", "MX", "AR", "CO", "US"])
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  competitors        Competitor[]
  keywordSearches    KeywordSearch[]
  marketAnalyses     MarketAnalysis[]
  trendOpportunities TrendOpportunity[]
}

// Singleton row to store the Meta access token
model Settings {
  id          String    @id @default("singleton")
  metaToken   String?
  tokenExpiry DateTime?
  countries   String[]  @default(["ES", "MX", "AR", "CO", "US"])
  updatedAt   DateTime  @updatedAt
}

// A competitor being monitored
model Competitor {
  id              String    @id @default(cuid())
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  fbPageName      String?
  fbPageId        String?
  websiteUrl      String?
  searchTerm      String?
  facebookUrl     String?
  instagramUrl    String?
  youtubeUrl      String?
  adLibraryUrl    String?
  semrushUrl      String?
  competitorType  String?   // 'directo' | 'indirecto'
  lastScrapedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Funnel Hacking fields (auto-filled by AI or edited manually)
  avatar           String?  @db.Text  // Target avatar: who, how identified, hook
  funnelUrl        String?            // Main sales funnel URL
  promesa          String?  @db.Text  // Lead magnet / free event promise
  promesaOferta    String?  @db.Text  // Offer promise: results, problems solved
  oferta           String?  @db.Text  // Offer name, value stack, deliverables
  bonos            String?  @db.Text  // Bonuses and why
  garantia         String?  @db.Text  // Product guarantee
  pruebasAutoridad String?  @db.Text  // Testimonials, awards, media
  precio           String?  @db.Text  // Price range (main offer + value ladder)
  embudoStructure  String?  @db.Text  // Detected funnel structure (e.g. ad > optin > vsl > checkout)
  funnelNotes      String?  @db.Text  // General notes
  funnelAnalyzedAt DateTime?

  ads              Ad[]
  landingPages     LandingPage[]
  scrapeJobs       ScrapeJob[]
  platformCourses  PlatformCourse[]
  marketAnalyses   MarketAnalysis[]
  organicPosts     OrganicPost[]

  @@index([clientId])
  @@index([fbPageId])
  @@index([name])
  @@index([competitorType])
}

// An ad from the Meta Ad Library
model Ad {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  metaAdId      String   @unique
  adCopyBodies  String[]
  headline      String?
  description   String?
  caption       String?
  ctaType       String?
  landingUrl    String?
  adSnapshotUrl String?
  imageUrls     String[]
  videoUrls     String[]
  platforms     String[]
  pageId        String?
  pageName      String?

  isActive    Boolean  @default(true)
  adStatus    String   @default("nuevo")  // nuevo, activo, winner, eliminado
  daysActive  Int      @default(0)
  startDate   DateTime?
  stopDate    DateTime?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // AI analysis tags (from Claude)
  aiAnalyzed      Boolean  @default(false)
  hookType        String?
  marketingAngle  String?
  creativeFormat  String?
  awarenessLevel  String?
  copyLength      String?
  copyStructure   String?
  ctaText         String?
  ctaUrgency      Boolean?
  offerPrice      String?
  offerDiscount   Boolean?
  offerBonuses    String?
  offerGuarantee  String?
  offerScarcity   String?
  aiScore         Int?
  aiSummary       String?

  landingPages LandingPage[]

  @@index([competitorId])
  @@index([isActive])
  @@index([adStatus])
  @@index([startDate])
  @@index([aiAnalyzed])
  @@index([hookType])
  @@index([marketingAngle])
  @@index([aiScore])
  @@index([competitorId, isActive])
  @@index([competitorId, adStatus])
}

// A scraped landing page
model LandingPage {
  id           String      @id @default(cuid())
  competitorId String?
  competitor   Competitor? @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  adId         String?
  ad           Ad?         @relation(fields: [adId], references: [id], onDelete: SetNull)

  url            String   @unique
  originalUrl    String
  title          String?
  h1Texts        String[]
  h2Texts        String[]
  ctaTexts       String[]
  prices         String[]
  offerName      String?
  bodyText       String?
  screenshotPath String?
  outboundLinks  String[]
  httpStatus     Int?
  scrapedAt      DateTime @default(now())
  scrapeError    String?
  createdAt      DateTime @default(now())

  funnelSteps FunnelStep[] @relation("FunnelStepPage")

  @@index([competitorId])
  @@index([adId])
}

// One step in a detected funnel chain
model FunnelStep {
  id           String      @id @default(cuid())
  competitorId String
  funnelId     String
  stepOrder    Int
  url          String
  pageType     String?
  landingPageId String?
  landingPage  LandingPage? @relation("FunnelStepPage", fields: [landingPageId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([competitorId])
  @@index([funnelId])
  @@unique([funnelId, stepOrder])
}

// Keyword-based competitor discovery search
model KeywordSearch {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  keywords  String
  niche     String?
  countries String[]
  createdAt DateTime @default(now())

  discoveredCompetitors DiscoveredCompetitor[]
  platformCourses       PlatformCourse[]

  @@index([clientId])
}

// A competitor discovered via keyword search (not yet added manually)
model DiscoveredCompetitor {
  id               String        @id @default(cuid())
  searchId         String
  search           KeywordSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  pageName         String
  pageId           String?
  adCount          Int           @default(0)
  sampleCopy       String?
  sampleLandingUrl String?
  competitorId     String?

  createdAt DateTime @default(now())

  @@index([searchId])
  @@index([pageId])
}

// A course/product found on external platforms (Udemy, Hotmart, Skool, Pylon)
model PlatformCourse {
  id            String         @id @default(cuid())
  searchId      String?
  search        KeywordSearch? @relation(fields: [searchId], references: [id], onDelete: SetNull)
  competitorId  String?
  competitor    Competitor?    @relation(fields: [competitorId], references: [id], onDelete: SetNull)
  platform      String
  title       String
  url         String         @unique
  authorName  String?
  price       String?
  rating      Float?
  reviewCount Int?
  description String?
  scrapedAt   DateTime       @default(now())

  comments PlatformComment[]

  @@index([platform])
  @@index([searchId])
  @@index([competitorId])
  @@index([competitorId, platform])
}

// A comment/review extracted from a platform course
model PlatformComment {
  id        String         @id @default(cuid())
  courseId  String
  course    PlatformCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author    String?
  text      String
  rating    Int?
  date      String?
  createdAt DateTime       @default(now())

  @@index([courseId])
}

// Market analysis generated by Claude from platform reviews
model MarketAnalysis {
  id             String      @id @default(cuid())
  clientId       String?
  client         Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  competitorId   String?
  competitor     Competitor? @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  searchKeywords String?

  objections     Json?       // [{ text, count }]
  benefits       Json?       // [{ text, count }]
  fears          Json?       // [{ text, count }]
  desires        Json?       // [{ text, count }]
  phrases        String[]    // Exact market language phrases
  awarenessLevel Json?       // { unaware, problemAware, solutionAware, productAware, mostAware }
  summary        String?

  totalReviews   Int         @default(0)
  platforms      String[]
  analyzedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())

  @@index([competitorId])
  @@index([clientId])
}

// Background job tracking
model ScrapeJob {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  jobType        String
  status         String   @default("PENDING")
  totalTasks     Int      @default(0)
  completedTasks Int      @default(0)
  failedTasks    Int      @default(0)
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([competitorId])
  @@index([status])
}

// Organic content from social platforms (Instagram, TikTok, YouTube)
model OrganicPost {
  id             String      @id @default(cuid())
  platform       String      // instagram, tiktok, youtube
  externalId     String      @unique
  url            String
  authorHandle   String
  authorName     String?
  competitorId   String?
  competitor     Competitor? @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  caption        String?
  hashtags       String[]
  mediaType      String?     // image, carousel, reel, video, short
  thumbnailUrl   String?
  duration       Int?        // seconds

  likes          Int         @default(0)
  comments       Int         @default(0)
  shares         Int         @default(0)
  views          Int         @default(0)
  followers      Int         @default(0)
  engagementRate Float?

  isViral        Boolean     @default(false)
  viralScore     Float?      // engagement / avg_engagement
  transcript     String?
  soundName      String?     // TikTok sound name

  publishedAt    DateTime?
  scrapedAt      DateTime    @default(now())
  searchKeywords String?

  @@index([platform])
  @@index([competitorId])
  @@index([isViral])
  @@index([publishedAt])
  @@index([authorHandle, platform])
  @@index([platform, scrapedAt])
}

// Cross-analysis opportunities (organic trends vs ads)
model TrendOpportunity {
  id           String   @id @default(cuid())
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type         String   // format_gap, hook_transfer, trending_topic, viral_sound
  title        String
  description  String
  source       String   // platform(s) where detected
  urgency      String   // high, medium, low
  relatedPosts String[] // OrganicPost IDs

  detectedAt   DateTime @default(now())
  dismissed    Boolean  @default(false)

  @@index([clientId])
  @@index([type])
  @@index([detectedAt])
}
